<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <SwitchPreference
        android:defaultValue="@bool/default_showIcons"
        android:key="showIcons"
        android:title="@string/pref_title_showIcons"
        android:summary="@string/pref_description_showIcons" />
    <SwitchPreference
        android:defaultValue="@bool/default_largeSingle"
        android:key="largeSingle"
        android:dependency="showIcons"
        android:title="@string/pref_title_largeSingle"
        android:summary="@string/pref_description_largeSingle" />

    <SwitchPreference
        android:defaultValue="@bool/default_headerSeparator"
        android:key="headerSeparator"
        android:title="@string/pref_title_headerSeparator"
        android:summary="@string/pref_description_headerSeparator" />

    <peterfajdiga.colorpickerhex.ColorPreference
        android:defaultValue="@integer/default_headerBgColor"
        android:key="headerBgColor"
        android:title="@string/pref_title_headerBgColor"
        app:editAlpha="true" />

</PreferenceScreen>
