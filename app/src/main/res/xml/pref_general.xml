<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <SwitchPreference
        android:defaultValue="@bool/default_allowOrientation"
        android:key="allowOrientation"
        android:title="@string/pref_title_allowOrientation"
        android:summary="@string/pref_description_allowOrientation" />

    <ListPreference
        android:defaultValue="@string/default_appItemResource"
        android:entries="@array/pref_appItemResource_titles"
        android:entryValues="@array/pref_appItemResource_values"
        android:key="appItemResource"
        android:negativeButtonText="@null"
        android:positiveButtonText="@null"
        android:title="@string/pref_title_appItemResource" />

    <SwitchPreference
        android:defaultValue="@bool/default_headerbtm"
        android:key="headerbtm"
        android:title="@string/pref_title_headerbtm"
        android:summary="@string/pref_description_headerbtm" />
    <SwitchPreference
        android:defaultValue="@bool/default_stackFromBottom"
        android:key="stackFromBottom"
        android:title="@string/pref_title_stackFromBottom"
        android:summary="@string/pref_description_stackFromBottom" />

    <SwitchPreference
        android:defaultValue="@bool/default_scrollableTabs"
        android:key="scrollableTabs"
        android:title="@string/pref_title_scrollableTabs"
        android:summary="@string/pref_description_scrollableTabs" />

    <SwitchPreference
        android:defaultValue="@bool/default_hideHidden"
        android:key="hideHidden"
        android:title="@string/pref_title_hideHidden"
        android:summary="@string/pref_description_hideHidden" />

</PreferenceScreen>
